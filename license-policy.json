{
  "$comment": "Dependency-license classification, enforced by scripts/check-licenses.mjs in CI. A license string pnpm reports that appears in neither list fails the build until it is classified here. Strings must match pnpm's exact output, including SPDX OR/AND expressions.",
  "allow": [
    "0BSD",
    "Apache-2.0",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "BlueOak-1.0.0",
    "CC-BY-4.0",
    "CC0-1.0",
    "ISC",
    "MIT",
    "MPL-2.0",
    "Python-2.0",
    "Unlicense",
    "WTFPL",
    "LGPL-2.1-only",
    "LGPL-2.1-or-later",
    "LGPL-3.0-only",
    "LGPL-3.0-or-later",
    "Apache-2.0 AND LGPL-3.0-or-later",
    "(BSD-2-Clause OR MIT OR Apache-2.0)",
    "(MIT OR CC0-1.0)",
    "(MIT OR WTFPL)"
  ],
  "deny": [
    "GPL-2.0-only",
    "GPL-2.0-or-later",
    "GPL-3.0-only",
    "GPL-3.0-or-later",
    "AGPL-3.0-only",
    "AGPL-3.0-or-later",
    "SSPL-1.0",
    "BUSL-1.1",
    "Elastic-2.0"
  ],
  "allowPackages": [
    "@anthropic-ai/claude-agent-sdk"
  ]
}
